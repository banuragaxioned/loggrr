{
  "name": "loggr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "start": "next start",
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "turbo": "next dev --turbo",
    "build": "next build",
    "push": "bunx prisma db push",
    "seed": "NODE_ENV=development prisma db seed",
    "reset": "bunx prisma db push --force-reset",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf .next",
    "fresh": "bun run clean && bun install && bun run dev",
    "studio": "prisma studio --browser none",
    "preview": "next build && next start",
    "lint": "eslint .",
    "taze": "taze",
    "format:write": "prettier --write \"**/*.{ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,mdx}\" --cache",
    "sonar-scanner": "sonar-scanner -Dsonar.projectKey=loggrr -Dsonar.sources=. -Dsonar.host.url=https://sonarqube.axioned.com",
    "analyze": "ANALYZE=true bun run build",
    "email": "email dev"
  },
